  <property name="styleSheet">
   <string notr="true">QWidget#Form {
    background-color: #151b24;
    color: #eafcff;
    font-family: &quot;Malgun Gothic&quot;;
    font-size: 10pt;
}

QWidget#page, QWidget#page_2, QWidget#page_3 {
    background-color: #1a212c;
    border: 1px solid #2c3947;
    border-radius: 24px;
}

QStackedWidget#stackedWidget {
    background: transparent;
    border: none;
}

QLabel {
    color: #eafcff;
    background: transparent;
    border: none;
}

QLabel#label_page, QLabel#label_page_2, QLabel#label_page_3 {
    color: #8ffcff;
    font-size: 18pt;
    font-weight: bold;
}

QLabel#battery_label {
    background-color: #222b37;
    color: #ffd24d;
    border: 2px solid #7fffd4;
    border-radius: 16px;
    padding-left: 14px;
    font-weight: bold;
}

QGroupBox {
    background-color: #212a35;
    border: 2px solid #9adf22;
    border-radius: 18px;
    margin-top: 12px;
    color: #8ffcff;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 14px;
    padding: 0 8px 0 8px;
    color: #ffb020;
}

QGroupBox#groupBox_page,
QGroupBox#groupBox_page_2,
QGroupBox#groupBox_page_3 {
    background-color: #212a35;
    border: 2px solid #7fffd4;
    border-radius: 18px;
}

QGroupBox#groupBox_btns {
    background-color: #1c2430;
    border: 2px solid #8ffcff;
    border-radius: 24px;
    color: #ffb020;
    font-size: 11pt;
}

QGroupBox#groupBox_go,
QGroupBox#groupBox_stop,
QGroupBox#groupBox_right,
QGroupBox#groupBox_left,
QGroupBox#groupBox_back,
QGroupBox#groupBox_face {
    background-color: #232d3a;
    border: 2px solid #ffb020;
    border-radius: 18px;
}

QGroupBox#groupBox_go:hover,
QGroupBox#groupBox_stop:hover,
QGroupBox#groupBox_right:hover,
QGroupBox#groupBox_left:hover,
QGroupBox#groupBox_back:hover {
    background-color: #293544;
    border: 2px solid #8ffcff;
}

QListWidget {
    background-color: #202934;
    color: #eafcff;
    border: 2px solid #8ffcff;
    border-radius: 18px;
    padding: 8px;
    outline: none;
}

QListWidget::item {
    background-color: #263240;
    border: 1px solid #3a495b;
    border-radius: 10px;
    padding: 8px 10px;
    margin: 4px 0px;
}

QListWidget::item:hover {
    border: 1px solid #9adf22;
    background-color: #2b3848;
}

QListWidget::item:selected {
    background-color: #314154;
    border: 1px solid #ffb020;
    color: #8ffcff;
}

QPushButton {
    background-color: #263240;
    color: #eafcff;
    border: 2px solid #8ffcff;
    border-radius: 16px;
    padding: 6px 12px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2d3b4c;
    border: 2px solid #ffb020;
}

QPushButton:pressed {
    background-color: #1a222c;
}

QPushButton#btn_pre,
QPushButton#btn_next,
QPushButton#btn_pre_2,
QPushButton#btn_next_2,
QPushButton#btn_pre_3,
QPushButton#btn_next_3 {
    background-color: #25313d;
    border: 2px solid #9adf22;
    color: #8ffcff;
    font-size: 10pt;
}

QPushButton#btn_pre:hover,
QPushButton#btn_next:hover,
QPushButton#btn_pre_2:hover,
QPushButton#btn_next_2:hover,
QPushButton#btn_pre_3:hover,
QPushButton#btn_next_3:hover {
    border: 2px solid #ffb020;
    color: #ffffff;
}

QPushButton#btn_go,
QPushButton#btn_stop,
QPushButton#btn_right,
QPushButton#btn_left,
QPushButton#btn_back {
    background-color: #263240;
    border: 2px solid #9adf22;
    border-radius: 18px;
    color: #ffb020;
    font-size: 22pt;
    font-weight: bold;
}

QPushButton#btn_face {
    background-color: #263240;
    border: 2px solid #9adf22;
    border-radius: 18px;
    color: #ffb020;
    font-size: 10pt;
    font-weight: bold;
}

QPushButton#btn_go:hover,
QPushButton#btn_stop:hover,
QPushButton#btn_right:hover,
QPushButton#btn_left:hover,
QPushButton#btn_back:hover,
QPushButton#btn_face:hover {
    border: 2px solid #8ffcff;
    color: #8ffcff;
    background-color: #304051;
}

QPushButton#btn_go:pressed,
QPushButton#btn_stop:pressed,
QPushButton#btn_right:pressed,
QPushButton#btn_left:pressed,
QPushButton#btn_back:pressed,
QPushButton#btn_face:pressed {
    background-color: #1b2530;
}

QTabWidget::pane {
    border: 2px solid #8ffcff;
    background-color: #202934;
    border-radius: 18px;
    top: -1px;
}

QTabBar::tab {
    background-color: #263240;
    color: #8ffcff;
    border: 2px solid #9adf22;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    padding: 8px 18px;
    margin-right: 4px;
    min-width: 90px;
}

QTabBar::tab:selected {
    background-color: #304051;
    color: #ffffff;
    border: 2px solid #ffb020;
}

QTabBar::tab:hover {
    background-color: #2d3b4c;
}
QLineEdit {
    background-color: #263240;
    color: #eafcff;
    border: 2px solid #8ffcff;
    border-radius: 30px;
    padding: 6px 12px;
    font-weight: bold;
}

